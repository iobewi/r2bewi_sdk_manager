{
  "name": "r2bewi-sdk-manager",
  "dockerComposeFile": "../docker/sdk/compose.yaml",
  "service": "r2bewi-sdk-manager",
  "workspaceFolder": "/workspace",
  "customizations": {
    "vscode": {
      "extensions": [
        "redhat.ansible",
        "ms-python.python",
        "timonwong.shellcheck"
      ]
    }
  },
  "remoteEnv": {
    "HOST_WORKSPACE_PATH": "${localWorkspaceFolder}"
  }
}